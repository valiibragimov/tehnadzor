{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "./src/client",
    "outDir": "./dist",
    "noCheck": false,
    "allowJs": false,
    "checkJs": false,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": [
    "src/client/**/*.ts",
    "src/client/**/*.d.ts"
  ],
  "exclude": [
    "app/vendor/**",
    "node_modules",
    "server/**",
    "functions/**"
  ]
}
