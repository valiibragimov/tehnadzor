# Firebase web config for the client build.
# Copy this file to .env and fill values from your Firebase project settings.
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=

# Optional hosted API endpoints consumed by window.__APP_CONFIG__ if you inject it yourself.
# AI_REPORT_API_BASE=
# BIM_IMPORT_API_BASE=
