PORT=5050

# Comma-separated origins, no trailing slash.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# true|false. Keep true in normal use.
AUTH_REQUIRED=true

# Rate limit for POST /generateReport
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# JSON body size limit
BODY_LIMIT=100kb

# Raw IFC import body size limit
IFC_IMPORT_BODY_LIMIT=25mb

# Optional: verify revoked tokens too (slower)
CHECK_REVOKED_TOKENS=false

# Firebase Admin credentials.
# Fallback order:
# 1. FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
# 2. FIREBASE_SERVICE_ACCOUNT_PATH
# 3. ./serviceAccount.local.json in the current working directory
# 3. Google applicationDefault() credentials
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.local.json
